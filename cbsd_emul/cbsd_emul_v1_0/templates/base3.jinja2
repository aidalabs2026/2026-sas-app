<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VIRTUAL CBSD V1.0</title>

    <!-- Kendo UI Stylesheet -->
    <link href="{{request.static_url('cbsd_emul_v1_0:static/css/kendo.default-v2.min.css')}}" rel="stylesheet" />
    <link href="{{request.static_url('cbsd_emul_v1_0:static/css/theme.css')}}" rel="stylesheet" />

    <!-- Kendo UI and jQuery -->
    <script src="{{request.static_url('cbsd_emul_v1_0:static/js/jquery-3.6.0.min.js')}}"></script>
    <script src="{{request.static_url('cbsd_emul_v1_0:static/js/kendo.all.min.js')}}"></script>
    <script src="{{request.static_url('cbsd_emul_v1_0:static/js/AppCommon.js')}}"></script>
    <script src="{{request.static_url('cbsd_emul_v1_0:static/js/mermaid.min.js')}}"></script>

    <style>
        /* ===== Layout ===== */
        html, body {
            margin: 0;
            padding: 0;
            height: 100%;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            background: #f0f2f5;
        }

        .app-wrapper {
            display: flex;
            flex-direction: column;
            height: 100vh;
        }

        /* ===== Header ===== */
        .app-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: #fff;
            padding: 10px 24px;
            box-shadow: 0 1px 4px rgba(0,0,0,0.08);
            z-index: 10;
            flex-shrink: 0;
        }
        .app-header .brand {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .app-header .brand img {
            height: 36px;
        }
        .app-header .brand h4 {
            margin: 0;
            color: #2c6ecb;
            font-weight: 700;
            font-size: 18px;
        }
        .app-header .brand h4 span {
            color: #17a2b8;
            font-weight: 500;
        }

        /* ===== Tab Navigation ===== */
        .tab-nav {
            display: flex;
            align-items: center;
            gap: 6px;
            background: #fff;
            padding: 0 24px;
            border-bottom: 1px solid #e0e0e0;
            flex-shrink: 0;
        }
        .tab-nav .tab-btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 10px 20px;
            border: none;
            background: transparent;
            color: #555;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            border-radius: 6px 6px 0 0;
            transition: background 0.2s, color 0.2s;
            position: relative;
        }
        .tab-nav .tab-btn:hover {
            background: #f0f4ff;
            color: #2c6ecb;
        }
        .tab-nav .tab-btn.active {
            background: #2c6ecb;
            color: #fff;
            border-radius: 6px;
            margin-bottom: 4px;
            margin-top: 4px;
        }
        .tab-nav .tab-btn .tab-icon {
            font-size: 15px;
        }

        /* ===== Main Content ===== */
        .app-body {
            display: flex;
            flex: 1;
            overflow: hidden;
            padding: 16px;
            gap: 16px;
        }

        /* Left Panel - CBSD List */
        .panel-left {
            width: 30%;
            min-width: 280px;
            display: flex;
            flex-direction: column;
        }
        .panel-left .card {
            flex: 1;
            display: flex;
            flex-direction: column;
            background: #fff;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.06);
            overflow: hidden;
        }

        /* Right Panel - Tab Content */
        .panel-right {
            width: 70%;
            display: flex;
            flex-direction: column;
        }
        .panel-right .card {
            flex: 1;
            display: flex;
            flex-direction: column;
            background: #fff;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.06);
            overflow: hidden;
        }

        /* Card header */
        .card-hdr {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px 16px;
            background: #fafbfc;
            border-bottom: 1px solid #e8e8e8;
            font-size: 14px;
            font-weight: 700;
            color: #333;
            flex-shrink: 0;
        }

        /* Card body */
        .card-bdy {
            flex: 1;
            overflow: auto;
            padding: 16px;
        }
        .card-bdy.no-pad {
            padding: 0;
        }

        /* Tab pane */
        .tab-pane {
            display: none !important;
        }
        .tab-pane.active {
            display: flex !important;
        }
        /* Non-flex tabs fall back to block-like behavior */
        #tab_channel.active, #tab_settings.active {
            display: block !important;
        }

        /* ===== Status Bar ===== */
        .app-statusbar {
            display: flex;
            align-items: center;
            gap: 24px;
            padding: 6px 24px;
            background: #fff;
            border-top: 1px solid #e0e0e0;
            font-size: 12px;
            color: #666;
            flex-shrink: 0;
        }
        .status-indicator {
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }
        .status-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #ccc;
        }
        .status-dot.connected {
            background: #4caf50;
        }
        .status-dot.disconnected {
            background: #f44336;
        }

        /* ===== Channel Badges in CBSD List ===== */
        .ch-badge-grant {
            display: inline-block; padding: 1px 5px; border-radius: 3px;
            font-size: 10px; font-weight: 600;
            background: #7efa5f; color: #333; margin: 1px;
        }
        .ch-badge-suspend {
            display: inline-block; padding: 1px 5px; border-radius: 3px;
            font-size: 10px; font-weight: 600;
            background: #ffb347; color: #fff; margin: 1px;
        }

        /* ===== Responsive ===== */
        @media (max-width: 992px) {
            .app-body {
                flex-direction: column;
            }
            .panel-left, .panel-right {
                width: 100%;
                min-width: 0;
            }
            .panel-left {
                max-height: 40vh;
            }
            .tab-nav {
                overflow-x: auto;
            }
        }
    </style>

    <script>
    var dataTable;
    var _grant_map = {};

    $(document).ready(function() {
        init();
        load();
        load_dpa();
        prop_load();
    });

    function init() {
        init_datatable();
    }

    function getChannelBadges(cbsdId) {
        var grants = _grant_map[cbsdId] || [];
        if (!grants.length) return '<span style="color:\\#bbb;">-</span>';
        return grants.map(function(g) {
            var cls = g.STATUS === 'SUSPEND' ? 'ch-badge-suspend' : 'ch-badge-grant';
            return '<span class="' + cls + '">' + g.CH_NO + '</span>';
        }).join(' ');
    }

    function init_datatable() {
        $("#dataTable").kendoGrid({
            sortable: true,
            selectable: true,
            toolbar: [
                { name: "search" },
                { name: "allStatus", text: "All" },
                { name: "registStatus", text: "Regist" },
                { name: "unregistStatus", text: "Unregist" },
                { name: "deleteRow", text: "Delete" }
            ],
            pageable: {
                responsive: false,
                pageSize: 12
            },
            search: {
                fields: [ "CBSD_ID" ]
            },
            columns: [
                {field: "ID", title: "ID", width: "60px"},
                {field: "FCC_ID", title: "FCC_ID", width: "90px"},
                {field: "CBSD_ID", title: "USER_ID", width: "90px"},
                {field: "STATUS", title: "STATUS", width: "70px"},
                {field: "CHANNELS", title: "CH", width: "100px", sortable: false,
                 template: "#= getChannelBadges(CBSD_ID) #"
                }
            ],
            selectable: "row",
            change: function(e) {
                var selectedRow = this.select();
                var dataItem = this.dataItem(selectedRow);
                var keys = Object.keys(dataItem)

                for( var i = 0 ; i < keys.length ; i++ )
                {
                    if(keys[i] == "STATUS" )
                        $("#status_label").text(dataItem[keys[i]])
                    else
                        $("#"+keys[i]).val(dataItem[keys[i]])
                }

                move_cbsd_marker(dataItem["LAT"],dataItem["LNG"])

                get_grant_list(dataItem.CBSD_ID)
                if ($("#tab_channel").hasClass("active")) { spectrumInquiry(null, null); }
                _msglog_cbsd_id = dataItem.CBSD_ID
                if ($("#tab_msglog").hasClass("active")) { loadMsgLog(); }
            },
        });
        dataTable = $("#dataTable").data("kendoGrid");

        $(document).on("click", ".k-grid-deleteRow", function () {
            var selected = dataTable.select();

            if (selected.length === 0) {
                alert("Please select a row to delete.");
                return;
            }

            var dataItem = dataTable.dataItem(selected);

            delete_cbsd_device(dataItem.ID)

            dataTable.removeRow(selected);
        });

        // ToolBar filter button events
        $("#dataTable .k-grid-allStatus").click(function() {
            dataTable.dataSource.filter([]);
        });

        $("#dataTable .k-grid-registStatus").click(function() {
            dataTable.dataSource.filter({ field: "STATUS", operator: "eq", value: "REGIST" });
        });

        $("#dataTable .k-grid-unregistStatus").click(function() {
            dataTable.dataSource.filter({ field: "STATUS", operator: "eq", value: "UNREGIST" });
        });
    }

    const ws = new WebSocket('ws://localhost:8765/ws');
    const messagesDiv = document.getElementById('messages');

    ws.onopen = () => {
        console.log('WebSocket connection opened');
        updateWsStatus(true);
    };

    ws.onmessage = (event) => {
        console.log(event.data)
        const jsonObject = JSON.parse(event.data);

        if( jsonObject.status == "SUSPENDED_GRANT" )
        {
            get_grant_list(jsonObject.cbsd_id)
        }
    };

    ws.onclose = () => {
        console.log('WebSocket connection closed');
        updateWsStatus(false);
    };

    ws.onerror = () => {
        updateWsStatus(false);
    };

    function updateWsStatus(connected) {
        var dot = document.getElementById('ws-status-dot');
        var label = document.getElementById('ws-status-label');
        if (dot) {
            dot.className = 'status-dot ' + (connected ? 'connected' : 'disconnected');
        }
        if (label) {
            label.textContent = connected ? 'SAS Connected' : 'SAS Disconnected';
        }
    }
    </script>
</head>
<body>
    <div class="app-wrapper">
        <!-- Header -->
        <div class="app-header">
            <div class="brand">
                <img src="data:image/png;base64," alt="ETRI Logo">
                <h4>VIRTUAL <span>CBSD - v1.0</span></h4>
            </div>
        </div>

        <!-- Tab Navigation -->
        <div class="tab-nav" id="tabNav">
            <button class="tab-btn active" data-tab="tab_cbsdinfo" onclick="switchTab(this)">
                <span class="tab-icon">&#128221;</span> CBSD Info
            </button>
            <button class="tab-btn" data-tab="tab_channel" onclick="switchTab(this)">
                <span class="tab-icon">&#128246;</span> Channel/Grant
            </button>
            <button class="tab-btn" data-tab="tab_msglog" onclick="switchTab(this)">
                <span class="tab-icon">&#128196;</span> Message Log
            </button>
            <button class="tab-btn" data-tab="tab_settings" onclick="switchTab(this)">
                <span class="tab-icon">&#9881;</span> Settings
            </button>
        </div>

        <!-- Main Body -->
        <div class="app-body">
            <!-- Left Panel: CBSD List -->
            <div class="panel-left">
                <div class="card">
                    <div class="card-hdr">CBSD List</div>
                    <div class="card-bdy no-pad">
                        <div id="dataTable" class="table-responsive scrollbar"></div>
                    </div>
                </div>
            </div>

            <!-- Right Panel: Tab Content -->
            <div class="panel-right">
                <div class="card">
                    <div class="card-hdr" id="rightPanelHeader">CBSD Info</div>
                    <div class="card-bdy">
                        <!-- Tab: CBSD Info + Map -->
                        <div class="tab-pane active" id="tab_cbsdinfo" style="display:flex; gap:12px; height:100%;">
                            <div style="flex:1; min-width:0; overflow-y:auto;">
                                <form>
                                    {% include "include/inc_cbsd_form.jinja2" %}
                                </form>
                            </div>
                            <div style="flex:1; min-width:0;">
                                {% include "include/inc_cbsd_map.jinja2" %}
                            </div>
                        </div>

                        <!-- Tab: Channel/Grant -->
                        <div class="tab-pane" id="tab_channel">
                            {% include "include/inc_cbsd_channel.jinja2" %}
                        </div>

                        <!-- Tab: Message Log (Inline) -->
                        <div class="tab-pane" id="tab_msglog" style="flex-direction:column; height:100%;">
                            {% include "include/inc_msglog.jinja2" %}
                        </div>

                        <!-- Tab: Settings -->
                        <div class="tab-pane" id="tab_settings">
                            {% include "include/inc_cbsd_sassetting.jinja2" %}
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Status Bar -->
        <div class="app-statusbar">
            <div class="status-indicator">
                <span class="status-dot disconnected" id="ws-status-dot"></span>
                <span id="ws-status-label">SAS Disconnected</span>
            </div>
            <div class="status-indicator">
                <span class="status-dot" id="hb-status-dot"></span>
                <span id="hb-status-label">Heartbeat: --</span>
            </div>
        </div>
    </div>
</body>
</html>

<script>
/* ===== Tab Switching ===== */
var _tabTitles = {
    "tab_cbsdinfo": "CBSD Info",
    "tab_channel": "Channel / Grant",
    "tab_msglog": "Message Log",
    "tab_settings": "Settings"
};

function switchTab(btn) {
    var tabId = $(btn).data("tab");

    // Update tab buttons
    $(".tab-nav .tab-btn").removeClass("active");
    $(btn).addClass("active");

    // Update panes
    $(".tab-pane").removeClass("active");
    $("#" + tabId).addClass("active");

    // Update right panel header
    $("#rightPanelHeader").text(_tabTitles[tabId] || tabId);

    // Trigger map resize when switching to CBSD Info (map is embedded there)
    if (tabId === "tab_cbsdinfo" && typeof map !== 'undefined') {
        setTimeout(function() { map.updateSize(); }, 100);
    }

    // Load messages when switching to Message Log tab
    if (tabId === "tab_msglog" && typeof loadMsgLog === 'function') {
        loadMsgLog();
    }
}

/* ===== Backward-compatible tab_move (kept for di_click_evt bindings) ===== */
function tab_move(obj) {
    var tgtId = $(obj).data("tgtid");
    // Map old tab IDs to new ones
    var mapping = {
        "tab_status": "tab_channel",
        "tab_map": "tab_map",
        "tab_sassetting": "tab_settings"
    };
    var newTabId = mapping[tgtId] || tgtId;
    var btn = $(".tab-nav .tab-btn[data-tab='" + newTabId + "']");
    if (btn.length) {
        switchTab(btn[0]);
    }
}

/* ===== Data Loading ===== */
function load() {
    loadGrantSummary(function() {
        $.ajax({
            url: '{{request.route_url("api/cbsd_list")}}',
            method: 'GET',
            success: function(response) {
                var data = JSON.parse(response);
                dataTable.setDataSource(data);
                init_cbsd_marker(data);
            },
            error: function() {
                console.log('Error occurred while fetching data.');
            }
        });
    });
}

function loadGrantSummary(callback) {
    $.ajax({
        url: '{{request.route_url("api/grant_summary")}}',
        method: 'GET',
        success: function(response) {
            var grants = JSON.parse(response);
            _grant_map = {};
            for (var i = 0; i < grants.length; i++) {
                var g = grants[i];
                if (!_grant_map[g.CBSD_ID]) _grant_map[g.CBSD_ID] = [];
                _grant_map[g.CBSD_ID].push(g);
            }
            if (callback) callback();
        },
        error: function() {
            if (callback) callback();
        }
    });
}

function load_dpa() {
    $.ajax({
        url: '{{request.route_url("api/dpa_list")}}',
        method: 'GET',
        success: function(response) {
            console.log(response);
            var data = JSON.parse(response);
            init_dpa_polygon(data.dpa_list);
            init_esc_marker(data.esc_list);
            console.log(data);
        },
        error: function() {
            console.log('Error occurred while fetching data.');
        }
    });
}

function get_grant_list(cbsdId) {
    _grant_list = null;
    $("#grant_ch_status").val("");
    $("#grant_freq_range").val("");
    $("#grantId2").val("");

    $.ajax({
        url: '{{request.route_url("api/grant_list")}}'+"?cbsd_id="+cbsdId,
        method: 'GET',
        success: function(response) {
            var data = JSON.parse(response);
            _grant_list = data;
            update_grant_table(data);
            // CBSD 목록의 CH 배지도 갱신
            refreshGrantBadges();
        },
        error: function() {
            console.log('Error occurred while fetching data.');
        }
    });
}

function refreshGrantBadges() {
    loadGrantSummary(function() {
        if (!dataTable) return;
        // CH 셀만 직접 업데이트 (grid refresh 없이)
        dataTable.tbody.find("tr").each(function() {
            var item = dataTable.dataItem(this);
            if (item) {
                $(this).find("td:last").html(getChannelBadges(item.CBSD_ID));
            }
        });
    });
}

function getServerUrl() {
    var protocol = window.location.protocol;
    var hostname = window.location.hostname;
    var port = window.location.port;
    var pathname = window.location.pathname;

    console.log(protocol + "://" + hostname + ":" + port + pathname);

    return protocol + "//" + hostname + ":" + port + pathname;
}

function delete_cbsd_device(cbsd_id) {
    $.ajax({
        url: '{{request.route_url("api/cbsd_delete")}}'+"?cbsd_id="+cbsd_id,
        method: 'GET',
        success: function(response) {
            console.log(response);
        },
        error: function() {
            console.log('Error occurred while fetching data.');
        }
    });
}
</script>
