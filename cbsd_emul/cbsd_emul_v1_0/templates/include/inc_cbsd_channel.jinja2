<style>
    .ch-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 12px;
    }
    .ch-table th {
        background: #f0f0f0;
        padding: 5px 8px;
        text-align: center;
        border: 1px solid #ddd;
        font-weight: 600;
        white-space: nowrap;
    }
    .ch-table td {
        padding: 4px 8px;
        border: 1px solid #ddd;
        text-align: center;
        vertical-align: middle;
    }
    .ch-table tr.selected-row {
        background: #e8f4fd !important;
    }
    .ch-table tr:hover {
        background: #f5f5f5;
        cursor: pointer;
    }

    /* Grant Status 색상 */
    .grant-badge {
        display: inline-block;
        padding: 2px 8px;
        border-radius: 3px;
        font-size: 11px;
        font-weight: 600;
        color: #333;
    }
    .grant-badge.authorized { background: #7efa5f; }
    .grant-badge.granted    { background: #9cf6f3; }
    .grant-badge.suspended  { background: #ffb347; color: #fff; }
    .grant-badge.idle       { background: #f4f4f4; }

    /* Spectrum Inquiry 바 차트 */
    .spectrum-bar-container {
        display: flex;
        width: 100%;
        height: 32px;
        border: 1px solid #ccc;
        border-radius: 4px;
        overflow: hidden;
        margin-bottom: 8px;
    }
    .spectrum-bar-segment {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 10px;
        font-weight: 600;
        border-right: 1px solid rgba(255,255,255,0.5);
        background: #e9e9e9;
        transition: background 0.3s;
        position: relative;
    }
    .spectrum-bar-segment:last-child { border-right: none; }
    .spectrum-bar-segment.available  { background: #7efa5f; }
    .spectrum-bar-segment.unavailable { background: #fea5a5; }
    .spectrum-bar-segment.unknown    { background: #e9e9e9; }

    .spectrum-freq-labels {
        display: flex;
        width: 100%;
        font-size: 9px;
        color: #888;
        margin-bottom: 4px;
    }
    .spectrum-freq-labels span {
        flex: 1;
        text-align: center;
    }

    .spectrum-legend {
        display: flex;
        gap: 12px;
        font-size: 11px;
        margin-bottom: 8px;
        flex-wrap: wrap;
    }
    .spectrum-legend .legend-item {
        display: flex;
        align-items: center;
        gap: 4px;
    }
    .spectrum-legend .legend-color {
        width: 12px;
        height: 12px;
        border-radius: 2px;
        border: 1px solid #ccc;
    }

    .action-bar {
        position: sticky;
        bottom: 0;
        background: #fff;
        display: flex;
        gap: 6px;
        padding: 8px 4px;
        border-top: 1px solid #e0e0e0;
        z-index: 10;
        justify-content: flex-end;
    }
</style>

