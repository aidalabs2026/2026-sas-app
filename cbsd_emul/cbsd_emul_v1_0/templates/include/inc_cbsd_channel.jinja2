<script>
var _grant_list = null;

/* --- Grant 테이블 업데이트 --- */
function update_grant_table(data) {
    // 모든 행 초기화
    for (var i = 1; i <= 10; i++) {
        $("#grant_status_" + i).text("IDLE").attr("class", "grant-badge idle");
        $("#grant_id_" + i).text("-");
        $("#grant_eirp_" + i).text("-");
        $("#grant_expire_" + i).text("-");
        $("#transmit_expire_" + i).text("-");
        $("#grant_row_" + i).find(".ch-relinquish-btn").hide();
        $("#grant_row_" + i).removeClass("selected-row");
    }

    if (!data) return;

    for (var i = 0; i < data.length; i++) {
        var item = data[i];
        var ch = item.CH_NO;
        if (!ch) continue;

        var statusClass = "idle";
        if (item.STATUS == "AUTHORIZED") statusClass = "authorized";
        else if (item.STATUS == "GRANTED") statusClass = "granted";
        else if (item.STATUS == "SUSPEND") statusClass = "suspended";

        $("#grant_status_" + ch).text(item.STATUS).attr("class", "grant-badge " + statusClass);
        $("#grant_id_" + ch).text(item.GRANT_ID || "-");
        $("#grant_eirp_" + ch).text(item.MAX_EIRP != null ? item.MAX_EIRP + " dBm" : "-");
        $("#grant_expire_" + ch).text(item.GRANT_EXPIRETIME || "-");
        $("#transmit_expire_" + ch).text(item.TRANSMIT_EXPIRETIME || "-");

        if (item.STATUS && item.STATUS != "IDLE") {
            $("#grant_row_" + ch).find(".ch-relinquish-btn").show();
        }
    }
}

/* --- 선택된 채널 정보 (글로벌) --- */
var _selected_ch = { low: null, high: null, chno: null };

/* --- 테이블 행 클릭 시 해당 채널 선택 (하위 호환) --- */
/* NOTE: document가 아닌 #grant_table_body에 바인딩 (AppCommon.js의 $(document).off() 회피) */
$("#grant_table_body").on("click", "tr", function() {
    $("#grant_table_body tr").removeClass("selected-row");
    $(this).addClass("selected-row");

    var chno = $(this).data("chno");
    var low = $(this).data("low");
    var high = $(this).data("high");

    _selected_ch = { low: low, high: high, chno: chno };

    // 하위 호환: hidden 필드 업데이트
    $("#grant_ch_status").val($("#grant_status_" + chno).text());
    $("#grant_freq_range").val(low + "-" + high);
    $("#grantId2").val($("#grant_id_" + chno).text() == "-" ? "" : $("#grant_id_" + chno).text());
    $("#grant_expiretime").val($("#grant_expire_" + chno).text() == "-" ? "" : $("#grant_expire_" + chno).text());
    $("#transmit_expiretime").val($("#transmit_expire_" + chno).text() == "-" ? "" : $("#transmit_expire_" + chno).text());
});

/* --- 인라인 Release 버튼 --- */
$("#grant_table_body").on("click", ".ch-relinquish-btn", function(e) {
    e.stopPropagation();
    var chno = $(this).data("chno");

    // 해당 채널의 grant_id 찾기
    var grantId = null;
    if (_grant_list) {
        for (var i = 0; i < _grant_list.length; i++) {
            if (_grant_list[i].CH_NO == chno) {
                grantId = _grant_list[i].GRANT_ID;
                break;
            }
        }
    }
    if (!grantId) return;

    // hidden 필드에 세팅 후 relinquishment 호출
    $("#grantId2").val(grantId);
    relinquishment(this);
});

/* --- 기존 함수들 (하위 호환 유지) --- */

function grant(obj, auto_grant_success=null, lowFreq=null, highFreq=null)
{
    var selectedRow = dataTable.select();

    // 채널 테이블에서 선택된 채널의 주파수 사용
    if (lowFreq == null && _selected_ch.low != null) {
        lowFreq = _selected_ch.low;
        highFreq = _selected_ch.high;
    }

    if( selectedRow.length == 0)
    {
        alert("CBSD 리스트에서 CBSD 를 선택하세요")
        return;
    }

    var dataItem = dataTable.dataItem(selectedRow);

    if( lowFreq == null || lowFreq == "")
    {
        auto_grant(dataItem)
        return;
    }

    var payload = {
        "cbsdId": dataItem.CBSD_ID,
        "operationParam": {
            "maxEirp": 30,
            "operationFrequencyRange": { "lowFrequency": lowFreq, "highFrequency": highFreq }
        }
    }

    $.ajax({
        url: '{{request.route_url("api/grant")}}',
        method: 'POST',
        contentType: 'application/json',
        data: JSON.stringify(payload),
        success: auto_grant_success != null ? auto_grant_success : function(response) {
            var code = response.response.responseCode
            var message = response.response.responseMessage
            if( code != 0 ) {
                alert("Error[Code : " + code + ", Message : " + message + "]")
            } else {
               alert("Success")
               get_grant_list(dataItem.CBSD_ID)
            }
        },
        error: function() { console.log('Error occurred while fetching data.'); }
    });
}

function auto_grant(data)
{
    if( data.STATUS == "DEREGIST" ) {
        regist(obj, auto_regist_success)
    }
    spectrumInquiry(data, auto_spectrumInquiry_success)
}

function auto_regist_success(data)
{
    spectrumInquiry(data, auto_spectrumInquiry_success)
}

function auto_spectrumInquiry_success(data)
{
    var code = data.response.responseCode
    var message = data.response.responseMessage

    if( code != 0 ) {
        alert("Error[Code : " + code + ", Message : " + message + "]")
    } else {
        var availableChannel = data.availableChannel;
        var maxEirp = 0;
        var channelCandidate = 0;

        // Spectrum 바 차트 초기화
        for (var i = 1; i <= 10; i++) {
            $("#inquery_ch" + i).removeClass("available unavailable").addClass("unknown");
        }

        for( var i = 0 ; i < availableChannel.length ; i++ )
        {
            var channel = availableChannel[i]
            var CH_NO = channel["frequencyRange"]["highFrequency"] % 3310000000 / 10000000 + 1
            var availEirp = channel["maxEirp"]

            if( availEirp > 0 ) {
                $("#inquery_ch" + CH_NO).removeClass("unknown unavailable").addClass("available");
                if( maxEirp < availEirp ) {
                    maxEirp = availEirp
                    channelCandidate = CH_NO
                }
            } else {
                $("#inquery_ch" + CH_NO).removeClass("unknown available").addClass("unavailable");
            }
        }

        if( channelCandidate == 0 ) {
            alert("가용한 채널이 없습니다.")
            return;
        }
        var freq = getFreqByChannel(channelCandidate)
        grant(data, auto_grant_success, freq.lowFreq, freq.highFreq)
    }
}

function getFreqByChannel(ch) {
    if (ch < 1 || ch > 10) {
        throw new Error("채널 번호는 1 ~ 10 사이여야 합니다.");
    }
    const lowFreq = 3300000000;
    const highFreq = 3310000000;
    const numChannels = 10;
    const step = (highFreq - lowFreq) / numChannels;
    const chLow = lowFreq + step * (ch - 1);
    const chHigh = chLow + step;
    return { lowFreq: chLow, highFreq: chHigh };
}

function auto_grant_success(data)
{
    var code = data.response.responseCode
    var message = data.response.responseMessage
    if( code != 0 ) {
        alert("Error[Code : " + code + ", Message : " + message + "]")
    } else {
        alert("Grant Success : grantId - " + data.grantId)
        get_grant_list(data.cbsdId)
    }
}

function relinquishment(obj)
{
    var selectedRow = dataTable.select();
    if( selectedRow.length == 0) {
        alert("CBSD 리스트에서 CBSD 를 선택하세요")
        return;
    }
    if( $("#grantId2").val() == "" ) return;

    var dataItem = dataTable.dataItem(selectedRow);
    var payload = {
        "cbsdId": dataItem.CBSD_ID,
        "grantId": $("#grantId2").val()
    }

    $.ajax({
        url: '{{request.route_url("api/relinquishment")}}',
        method: 'POST',
        contentType: 'application/json',
        data: JSON.stringify(payload),
        success: function(response) {
            var code = response.response.responseCode
            var message = response.response.responseMessage
            if( code != 0 ) {
                alert("Error[Code : " + code + ", Message : " + message + "]")
            } else {
               alert("Success")
               get_grant_list(dataItem.CBSD_ID)
            }
        },
        error: function() { console.log('Error occurred while fetching data.'); }
    });
}

function get_grant(obj)
{
    // 하위 호환 유지 (기존 버튼 클릭 방식 - 이제 테이블 클릭으로 대체됨)
    var ch_no = $(obj).data("chno");
    $("#grant_table_body tr").removeClass("selected-row");
    $("#grant_row_" + ch_no).addClass("selected-row").trigger("click");
}

function flowView()
{
    var cbsdId = $("#CBSD_ID").val();
    if (!cbsdId) return;

    // Message Log 탭으로 전환
    var btn = $(".tab-nav .tab-btn[data-tab='tab_msglog']");
    if (btn.length) { switchTab(btn[0]); }

    // 메시지 로드
    loadMsgLog(cbsdId);
}

function flowTableView()
{
    var cbsdId = $("#CBSD_ID").val()
    if( cbsdId == null || cbsdId == "") return;
    getServerUrl()
    const videoUrl = getServerUrl()+'msglogview/' + cbsdId;
    const windowFeatures = 'width=1200,height=600,resizable=yes,scrollbars=yes,status=no';
    const newWindow = window.open(videoUrl, 'CBSD MESSAGE FLOW V1.0', windowFeatures);
}
</script>
