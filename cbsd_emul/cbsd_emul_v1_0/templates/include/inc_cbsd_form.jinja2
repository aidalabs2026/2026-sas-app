<style>
.accordion-section { margin-bottom: 2px; }
.accordion-header {
    display: flex; align-items: center; gap: 6px;
    padding: 5px 8px; background: #f5f6f8; border: 1px solid #e0e0e0;
    border-radius: 3px; cursor: pointer; user-select: none;
    font-size: 12px; font-weight: 600; color: #333;
}
.accordion-header:hover { background: #ebedf0; }
.accordion-header .arrow { transition: transform 0.2s; font-size: 10px; }
.accordion-header.collapsed .arrow { transform: rotate(-90deg); }
.accordion-body { padding: 6px 4px; }
.accordion-body.hidden { display: none; }
.compact-form .form-label { font-size: 11px; margin-bottom: 1px; color: #555; }
.compact-form .form-control, .compact-form .form-select {
    font-size: 12px; padding: 3px 6px; height: 28px;
}
.compact-form .row { margin-bottom: 4px; }
.compact-form .checkbox-group { font-size: 11px; }
.compact-form .checkbox-group label { display: flex; align-items: center; gap: 4px; }
.action-bar-sticky {
    position: sticky; bottom: 0; background: #fff;
    border-top: 1px solid #e0e0e0; padding: 8px 4px;
    z-index: 10; display: flex; gap: 6px; justify-content: flex-end;
}
</style>

<div class="form_container compact-form">

    <!-- Basic Info -->
    <div class="accordion-section">
        <div class="accordion-header" onclick="toggleAccordion(this)">
            <span class="arrow">&#9660;</span> Basic Info
        </div>
        <div class="accordion-body">
            <div class="row g-1">
                <div class="col-4">
                    <label class="form-label">USER ID</label>
                    <input type="text" id="USER_ID" class="form-control">
                </div>
                <div class="col-4">
                    <label class="form-label">FCC ID</label>
                    <input type="text" id="FCC_ID" class="form-control">
                </div>
                <div class="col-4">
                    <label class="form-label">Category</label>
                    <input type="text" id="CATEGORY" class="form-control">
                </div>
            </div>
            <div class="row g-1">
                <div class="col-4">
                    <label class="form-label">Call Sign</label>
                    <input type="text" id="CALL_SIGN" class="form-control">
                </div>
                <div class="col-4">
                    <label class="form-label">Serial Number</label>
                    <input type="text" id="SN" class="form-control">
                </div>
                <div class="col-4">
                    <label class="form-label">CBSD ID</label>
                    <input type="text" id="CBSD_ID" class="form-control" readonly style="background:#f0f0f0;">
                </div>
            </div>
        </div>
    </div>

    <!-- Radio & Device -->
    <div class="accordion-section">
        <div class="accordion-header collapsed" onclick="toggleAccordion(this)">
            <span class="arrow">&#9660;</span> Radio & Device
        </div>
        <div class="accordion-body hidden">
            <div class="row g-1">
                <div class="col-4">
                    <label class="form-label">Radio Tech</label>
                    <input type="text" id="RADIO_TECH" class="form-control">
                </div>
                <div class="col-4">
                    <label class="form-label">Supported Spec</label>
                    <input type="text" id="SUPP_SPEC" class="form-control">
                </div>
                <div class="col-4">
                    <label class="form-label">Vendor</label>
                    <input type="text" id="VENDOR" class="form-control">
                </div>
            </div>
            <div class="row g-1">
                <div class="col-6">
                    <label class="form-label">Meas. Capability</label>
                    <div class="checkbox-group">
                        <label><input type="checkbox" value="RECEIVED_POWER_WITHOUT_GRANT"> RX PWR W/O GRANT</label>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Location -->
    <div class="accordion-section">
        <div class="accordion-header" onclick="toggleAccordion(this)">
            <span class="arrow">&#9660;</span> Location
        </div>
        <div class="accordion-body">
            <div class="row g-1">
                <div class="col-4">
                    <label class="form-label">Latitude</label>
                    <input type="text" id="LAT" class="form-control">
                </div>
                <div class="col-4">
                    <label class="form-label">Longitude</label>
                    <input type="text" id="LNG" class="form-control">
                </div>
                <div class="col-4">
                    <label class="form-label">Height (m)</label>
                    <input type="text" id="HEIGHT" class="form-control">
                </div>
            </div>
            <div class="row g-1">
                <div class="col-4">
                    <label class="form-label">Height Type</label>
                    <select id="HEIGHT_TYPE" class="form-select">
                        <option value="AGL">AGL</option>
                        <option value="AMSL">AMSL</option>
                    </select>
                </div>
                <div class="col-4">
                    <label class="form-label">Indoor</label>
                    <input type="text" id="INDOOR" class="form-control">
                </div>
            </div>
        </div>
    </div>

    <!-- Antenna -->
    <div class="accordion-section">
        <div class="accordion-header collapsed" onclick="toggleAccordion(this)">
            <span class="arrow">&#9660;</span> Antenna
        </div>
        <div class="accordion-body hidden">
            <div class="row g-1">
                <div class="col-3">
                    <label class="form-label">Azimuth</label>
                    <input type="text" id="ANT_AZIM" class="form-control">
                </div>
                <div class="col-3">
                    <label class="form-label">Downtilt</label>
                    <input type="text" id="ANT_DWN" class="form-control">
                </div>
                <div class="col-3">
                    <label class="form-label">Gain (dBi)</label>
                    <input type="text" id="ANT_GAIN" class="form-control">
                </div>
                <div class="col-3">
                    <label class="form-label">Beamwidth</label>
                    <input type="text" id="ANT_BWIDTH" class="form-control">
                </div>
            </div>
        </div>
    </div>

    <input type="hidden" id="EIRP_CAPA" name="EIRP_CAPA"/>
</div>

<!-- Sticky action bar -->
<div class="action-bar-sticky">
    <input type="button" class="btn btn-primary btn-sm di_click_evt" id="regist" data-func="regist" value="Regist"/>
    <input type="button" class="btn btn-secondary btn-sm di_click_evt" id="deregist" data-func="deregist" value="Deregist"/>
    <input type="button" class="btn btn-primary btn-sm di_click_evt" id="spectrumInquiry" data-func="spectrumInquiry" value="Spectrum Inquiry"/>
</div>

<script>
function toggleAccordion(header) {
    var body = header.nextElementSibling;
    header.classList.toggle("collapsed");
    body.classList.toggle("hidden");
}

function regist(obj, auto_regist_success = null)
{
    var dataItem = getFormDataAsJson();
    var payload = {
        "fccId": dataItem.FCC_ID,
        "cbsdCategory": dataItem.CATEGORY,
        "callSign": dataItem.CALL_SIGN,
        "userId": dataItem.USER_ID,
        "airInterface": { "radioTechnology": dataItem.RADIO_TECH, "supportedSpec": dataItem.SUPP_SPEC },
        "cbsdInfo": { "vendor": dataItem.VENDOR },
        "cbsdSerialNumber": dataItem.SN,
        "measCapability": "RECEIVED_POWER_WITHOUT_GRANT",
        "installationParam": {
            "latitude": dataItem.LAT, "longitude": dataItem.LNG,
            "height": dataItem.HEIGHT, "heightType": dataItem.HEIGHT_TYPE,
            "indoorDeployment": dataItem.INDOOR,
            "antennaAzimuth": dataItem.ANT_AZIM, "antennaDowntilt": dataItem.ANT_DWN,
            "antennaGain": dataItem.ANT_GAIN, "antennaBeamwidth": dataItem.ANT_BWIDTH
        },
        "eirpCapa": dataItem.EIRP_CAPA
    }
    $.ajax({
        url: '{{request.route_url("api/regist")}}', method: 'POST',
        contentType: 'application/json', data: JSON.stringify(payload),
        success: auto_regist_success != null ? auto_regist_success : function(response) {
            var code = response.response.responseCode;
            var message = response.response.responseMessage;
            var cbsdId = response.cbsdId;
            if (code != 0) { alert("Error[Code : " + code + ", Message : " + message + "]"); }
            else {
                var selectedRow = dataTable.select();
                if (selectedRow.length > 0) { selectedRow.trigger("click"); }
                load();
                dataTable.tbody.find("tr").each(function() {
                    var dataItem = dataTable.dataItem(this);
                    if (dataItem.CBSD_ID === cbsdId) { $(this).click(); }
                });
            }
        },
        error: function() { console.log('Error occurred while fetching data.'); }
    });
}

function deregist(obj)
{
    var selectedRow = dataTable.select();
    if (selectedRow.length == 0) { alert("선택된 CBSD가 없습니다."); return; }
    var payload = { "cbsdId": $("#CBSD_ID").val() }
    $.ajax({
        url: '{{request.route_url("api/deregist")}}', method: 'POST',
        contentType: 'application/json', data: JSON.stringify(payload),
        success: function(response) {
            var code = response.response.responseCode;
            var message = response.response.responseMessage;
            var cbsdId = response.cbsdId;
            if (code != 0) { alert("Error[Code : " + code + ", Message : " + message + "]"); }
            else {
                var selectedRow = dataTable.select();
                if (selectedRow.length > 0) { selectedRow.trigger("click"); }
                load();
                dataTable.tbody.find("tr").each(function() {
                    var dataItem = dataTable.dataItem(this);
                    if (dataItem.CBSD_ID === cbsdId) { $(this).click(); }
                });
                alert("Success");
            }
        },
        error: function() { console.log('Error occurred while fetching data.'); }
    });
}

function spectrumInquiry(obj, auto_spectrumInquiry_success = null)
{
    var selectedRow = dataTable.select();
    if (selectedRow.length == 0) { alert("선택된 CBSD가 없습니다."); return; }
    var payload = {
        "cbsdId": $("#CBSD_ID").val(),
        "inquiredSpectrum": [
            { "lowFrequency": 3300000000, "highFrequency": 3310000000 },
            { "lowFrequency": 3310000000, "highFrequency": 3320000000 },
            { "lowFrequency": 3320000000, "highFrequency": 3330000000 },
            { "lowFrequency": 3330000000, "highFrequency": 3340000000 },
            { "lowFrequency": 3340000000, "highFrequency": 3350000000 },
            { "lowFrequency": 3350000000, "highFrequency": 3360000000 },
            { "lowFrequency": 3360000000, "highFrequency": 3370000000 },
            { "lowFrequency": 3370000000, "highFrequency": 3380000000 },
            { "lowFrequency": 3380000000, "highFrequency": 3390000000 },
            { "lowFrequency": 3390000000, "highFrequency": 3400000000 }
        ]
    }
    $.ajax({
        url: '{{request.route_url("api/spectrumInquery")}}', method: 'POST',
        contentType: 'application/json', data: JSON.stringify(payload),
        success: auto_spectrumInquiry_success != null ? auto_spectrumInquiry_success : function(response) {
            var code = response.response.responseCode;
            var message = response.response.responseMessage;
            if (code != 0) { alert("Error[Code : " + code + ", Message : " + message + "]"); }
            else {
                var availableChannel = response.availableChannel;
                for (var i = 0; i < availableChannel.length; i++) {
                    var channel = availableChannel[i];
                    var CH_NO = channel["frequencyRange"]["highFrequency"] % 3310000000 / 10000000 + 1;
                    var availEirp = channel["maxEirp"];
                    $("#inquery_ch" + CH_NO).removeClass("available unavailable unknown");
                    if (availEirp > 0) { $("#inquery_ch" + CH_NO).addClass("available"); }
                    else { $("#inquery_ch" + CH_NO).addClass("unavailable"); }
                }
            }
        },
        error: function() { console.log('Error occurred while fetching data.'); }
    });
}

function getFormDataAsJson() {
    const formData = {};
    $('.form_container input[id], .form_container select[id]').each(function() {
        formData[this.id] = $(this).val();
    });
    return formData;
}
</script>
