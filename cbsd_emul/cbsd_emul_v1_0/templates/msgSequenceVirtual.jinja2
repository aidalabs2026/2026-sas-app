  function renderMessagesChunk(index) {
    if (renderedChunks.includes(index)) return;

    const end = Math.min(index + chunkSize, totalMessages.length);
    const messages = totalMessages.slice(index, end);
    if (messages.length === 0) return;

    const code = [
      "sequenceDiagram",
      ...messages.map(m => `${m.from}->>${m.to}: ${m.message}`)
    ].join("\n");

    mermaid.render(`chunk_${index}`, code).then(({ svg }) => {
      const div = document.createElement("div");
      div.classList.add("diagram-chunk");
      div.setAttribute("data-chunk-index", index);
      div.innerHTML = svg;

      if (index < baseIndex) {
        container.insertBefore(div, container.children[1]);
        wrapper.scrollTop += div.clientHeight + 40;
        renderedChunks.unshift(index);
      } else {
        container.appendChild(div);
        renderedChunks.push(index);
      }

      // ✅ 최대 chunk 개수 초과 시 제거
      if (renderedChunks.length > maxChunks) {
        const removeIndex = index < baseIndex ? renderedChunks.pop() : renderedChunks.shift();
        const oldDiv = container.querySelector(`[data-chunk-index="${removeIndex}"]`);
        if (oldDiv) container.removeChild(oldDiv);
      }
    });
  }

  function dataSort(data)
  {
    // 1️⃣ REGIST_DT에서 .(dot) 뒤의 마이크로초 제거
    data.forEach(item => {
      item.REGIST_DT = item.REGIST_DT.replace(/\.\d+/, ''); // ".812000" 같은 부분 제거
    });

    // 2️⃣ REGIST_DT 기준으로 오름차순 정렬 (최신 데이터가 뒤로)
    data.sort((a, b) => new Date(a.REGIST_DT) - new Date(b.REGIST_DT));

    return data;
  }
