                                                                    <a class="nav-link mb-0 d-flex align-items-center gap-1 py-3 px-x1 active" id="contact-tab_status-tab" data-bs-toggle="tab" href="#tab_status" role="tab" aria-controls="tab_status" aria-selected="true"><svg class="svg-inline--fa fa-stream fa-w-16 icon text-600" aria-hidden="true" focusable="false" data-prefix="fas" data-icon="stream" role="img" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" data-fa-i2svg=""><path fill="currentColor" d="M16 128h416c8.84 0 16-7.16 16-16V48c0-8.84-7.16-16-16-16H16C7.16 32 0 39.16 0 48v64c0 8.84 7.16 16 16 16zm480 80H80c-8.84 0-16 7.16-16 16v64c0 8.84 7.16 16 16 16h416c8.84 0 16-7.16 16-16v-64c0-8.84-7.16-16-16-16zm-64 176H16c-8.84 0-16 7.16-16 16v64c0 8.84 7.16 16 16 16h416c8.84 0 16-7.16 16-16v-64c0-8.84-7.16-16-16-16z"></path></svg><!-- <span class="fas fa-stream icon text-600"></span> Font Awesome fontawesome.com -->
                                                                        <h6 class="mb-0 text-600">Channel Status</h6>
                                                                    </a>
                                                                </li>
                                                                <li class="nav-item text-nowrap di_click_evt" role="presentation" data-func="tab_move" data-tgtid="tab_map">
                                                                    <a class="nav-link mb-0 d-flex align-items-center gap-1 py-3 px-x1" id="contact-tab_map-tab" data-bs-toggle="tab" href="#tab_map" role="tab" aria-controls="tab_map" aria-selected="true"><svg class="svg-inline--fa fa-stream fa-w-16 icon text-600" aria-hidden="true" focusable="false" data-prefix="fas" data-icon="stream" role="img" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" data-fa-i2svg=""><path fill="currentColor" d="M16 128h416c8.84 0 16-7.16 16-16V48c0-8.84-7.16-16-16-16H16C7.16 32 0 39.16 0 48v64c0 8.84 7.16 16 16 16zm480 80H80c-8.84 0-16 7.16-16 16v64c0 8.84 7.16 16 16 16h416c8.84 0 16-7.16 16-16v-64c0-8.84-7.16-16-16-16zm-64 176H16c-8.84 0-16 7.16-16 16v64c0 8.84 7.16 16 16 16h416c8.84 0 16-7.16 16-16v-64c0-8.84-7.16-16-16-16z"></path></svg><!-- <span class="fas fa-stream icon text-600"></span> Font Awesome fontawesome.com -->
