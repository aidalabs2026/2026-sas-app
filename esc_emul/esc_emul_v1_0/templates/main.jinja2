</body>
</html>
<script>
function load() {
    $.ajax({
        url: '{{request.route_url("api/esc_list")}}',  // AJAX 요청할 URL
        method: 'GET',
        success: function(response) {
            console.log(response);  // 응답 처리

            var data = JSON.parse(response);

           dataTable.setDataSource(data);

           init_esc_marker(data)

            console.log(data)
        },
        error: function() {
            console.log('Error occurred while fetching data.');
        }
    });
}

function load_dpa() {
    $.ajax({
        url: '{{request.route_url("api/dpa_list")}}',  // AJAX 요청할 URL
        method: 'GET',
        success: function(response) {
            console.log(response);  // 응답 처리

            var data = JSON.parse(response);
            init_dpa_polygon(data.dpa_list)
            init_cbsd_marker(data.cbsd_list)

            console.log(data)
        },
        error: function() {
            console.log('Error occurred while fetching data.');
        }
    });
}

function get_ch_list(sensorId) {

    _ch_list = null

    $("#ch_status").val("")
    $("#ch_freq_range").val("")

    $.ajax({
        url: '{{request.route_url("api/esc_ch_list")}}'+"?sensor_id="+sensorId,  // AJAX 요청할 URL
        method: 'GET',
        success: function(response) {
            console.log(response);  // 응답 처리

            var data = JSON.parse(response);

            for( var i = 1 ; i < 11 ; i++ )
            {
                $("#ch" + i).css("background-color", "#7efa5f")
            }

            _ch_list = data

            for( var i = 0 ; i < data.length ; i++ )
            {
                var item = data[i]
                if( item.INCUMBENT_USER == 1 )
                    $("#ch" + item.CH_NO).css("background-color", "ORANGE")
                else
                    $("#ch" + item.CH_NO).css("background-color", "#7efa5f")
            }

            console.log(data)
        },
        error: function() {
            console.log('Error occurred while fetching data.');
        }
    });
}

function delete_esc_sensor(sensorId) {

    $.ajax({
        url: '{{request.route_url("api/esc_sensor_delete")}}'+"?sensor_id="+sensorId,  // AJAX 요청할 URL
        method: 'GET',
        success: function(response) {
            console.log(response);  // 응답 처리


        },
        error: function() {
            console.log('Error occurred while fetching data.');
        }
    });
}


function tab_move(obj)
{
    var tgtId = $(obj).data("tgtid")
    $(".text-nowrap").find("a").removeClass("active")
    $(obj).find("a").addClass("active")

    $("#tab_status").removeClass("active")
    $("#tab_map").removeClass("active")

    $("#"+tgtId).addClass("active")
}

function getServerUrl()
{
    var protocol = window.location.protocol
    var hostname = window.location.hostname
    var port = window.location.port
    var pathname = window.location.pathname

    console.log(protocol + "://" + hostname + ":" + port + pathname)

    return protocol + "//" + hostname + ":" + port + pathname
}
</script>