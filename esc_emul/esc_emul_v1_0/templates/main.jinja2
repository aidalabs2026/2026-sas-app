                <form class>
                    <div class="g-3 row">
                        <div class="col-lg-4">
                            <div class="sticky-sidebar">
                                <div class="mb-3 card">
                                    <h6 class="bg-body-tertiary card-header">ESC List</h6>
                                    <div class="p-0 card-body">
                                        <div id="dataTable" class="table-responsive scrollbar"></div>
                                    </div>
                                </div>

                            </div>
                        </div>
                        <div class="col-lg-4">
                            <div class="sticky-sidebar">
                                <div class="mb-3 card">
                                    <h6 class="bg-body-tertiary card-header">Information</h6>
                                    <div class="card-body">
                                        <form>
                                            {% include "include/inc_esc_form.jinja2" %}
                                        </form>
                                    </div>
                                </div>

                            </div>
                        </div>
                        <div class="col-lg-4">
                            <div class="sticky-sidebar">
                                <div class="mb-3 card">
                                    <div class="card-header p-0 scrollbar-overlay border-bottom" style="height: 50px;" data-simplebar="init">
                                        <div class="simplebar-wrapper" style="margin: 0px;">
