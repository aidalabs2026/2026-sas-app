<!DOCTYPE html>
<html lang="en" class="windows chrome">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VIRTUAL ESC V1.0</title>
    <!-- Kendo UI Stylesheet -->
    <link href="{{request.static_url('esc_emul_v1_0:static/css/kendo.default-v2.min.css')}}" rel="stylesheet" />

    <link href="{{request.static_url('esc_emul_v1_0:static/css/theme.css')}}" rel="stylesheet" />

    <!-- Kendo UI and jQuery -->
    <script src="{{request.static_url('esc_emul_v1_0:static/js/jquery-3.6.0.min.js')}}"></script>
    <script src="{{request.static_url('esc_emul_v1_0:static/js/kendo.all.min.js')}}"></script>
    <script src="{{request.static_url('esc_emul_v1_0:static/js/AppCommon.js')}}"></script>
    <script src="{{request.static_url('esc_emul_v1_0:static/js/echarts.min.js')}}"></script>
    <script>
    var dataTable;

    $(document).ready(function() {
        init();

        load();
        load_dpa();
    });

    function init()
    {
        init_datatable()
    }

    function init_datatable() {
        $("#dataTable").kendoGrid({
            sortable: true,
            selectable: true,
            pageable: false,
            toolbar: [
                { name: "deleteRow", text: "🗑 삭제" }
            ],
            columns: [
                {field: "ID", title: "ID", width: "100px"},
                {field: "SENSOR_ID", title: "ESC ID", width: "100px"},
                {field: "LAT", title: "LAT.", width: "160px"},
                {field: "LNG", title: "LNG.", width: "100px"},
                {field: "HEIGHT", title: "HEIGHT", width: "100px"},
                {field: "HEIGHT_TYPE", title: "HEIGHT_TYPE", width: "100px"}
            ],
            // 로우 클릭 이벤트 핸들러
            selectable: "row",
            change: function(e) {
                var selectedRow = this.select();
                var dataItem = this.dataItem(selectedRow);
                var keys = Object.keys(dataItem)

                for( var i = 0 ; i < keys.length ; i++ )
                {
                    if(keys[i] == "STATUS" )
                        $("#status_label").text(dataItem[keys[i]])
                    else if(keys[i] == "AZIMUTH_RAD_PATTERN") {
                        var radarData = JSON.parse(dataItem[keys[i]])
                        init_chart("radarChart", radarData)
                    }
                    else if(keys[i] == "ELEVATION_RAD_PATTERN") {
                        var radarData = JSON.parse(dataItem[keys[i]])
                        init_chart("radarChart2", radarData)
                    }
                    else
                        $("#"+keys[i]).val(dataItem[keys[i]])
                }
                move_esc_marker(dataItem["LAT"],dataItem["LNG"])
                get_ch_list(dataItem.SENSOR_ID)
                get_sensing_status(dataItem.SENSOR_ID)
            }
        });
        dataTable = $("#dataTable").data("kendoGrid");

        $(document).on("click", ".k-grid-deleteRow", function () {
            var selected = dataTable.select();

            if (selected.length === 0) {
                alert("삭제할 행을 선택하세요.");
                return;
            }

            var dataItem = dataTable.dataItem(selected);       // <-- 여기!

            delete_esc_sensor(dataItem.ID)

            dataTable.removeRow(selected);
        });
    }

    function init_chart(name, data)
    {
        /*
        const data = [
            {"gain": 20, "angle": 1}, {"gain": 20, "angle": 2}, {"gain": 20, "angle": 3},
            {"gain": 20, "angle": 4}, {"gain": 20, "angle": 5}, {"gain": 20, "angle": 6},
            // ... 생략 ...
            {"gain": 20, "angle": 359}, {"gain": 20, "angle": 360}
        ];
        */
        // ECharts 인스턴스 생성
        const chartDom = document.getElementById(name);
        const myChart = echarts.init(chartDom);

        // 각도 배열과 값 배열 생성
        const polarDatas = data.map(item => [item.gain, item.angle]);
        const gains = data.map(item => item.gain);

        // 옵션 설정
        option = {
          title: {
            text: ''
          },
          legend: {
            data: ['gain'],
            show:false
          },
          polar: {},
          tooltip: {
            trigger: 'axis',
            axisPointer: {
              type: 'cross'
            },
            formatter: function (params) {
              // 툴팁에서 angle과 gain을 함께 표시
              return `Angle: ${params[0].value[1]}°, Gain: ${params[0].value[0]}`;
            }
          },
          angleAxis: {
            type: 'value',
            startAngle: 0
          },
          radiusAxis: {},
          series: [
            {
              coordinateSystem: 'polar',
              name: 'gain',
              type: 'line',
              data: polarDatas
            }
          ]
        };
        // 옵션 설정 및 차트 표시
        myChart.setOption(option);
    }

    const ws = new WebSocket('ws://localhost:8766/ws');
    const messagesDiv = document.getElementById('messages');

    ws.onopen = () => {
        console.log('WebSocket connection opened');
    };

    ws.onmessage = (event) => {
        console.log(event.data)
        const jsonObject = JSON.parse(event.data);

        if( jsonObject.status == "SUSPENDED_GRANT" )
        {
            //alert("channel SUSPENDED_GRANT")
            get_grant_list(jsonObject.cbsd_id)
        }

    };

    ws.onclose = () => {
        console.log('WebSocket connection closed');
    };

    </script>

</head>
<body>
