                    </div>
                </form>
            </div>
        </div>
    </main>

    <script>
        // Kendo Grid 초기화
        $(document).ready(function () {
            $("#grid").kendoGrid({
                dataSource: {
                    data: [
                        { name: "홍길동", age: 30, city: "서울" },
                        { name: "김영희", age: 25, city: "부산" },
