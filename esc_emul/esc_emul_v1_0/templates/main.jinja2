        <div class="container">
            <div class="content">
                <div class="shadow-none border card" style="margin-bottom:10px;">
                    <div class="z-1 card-header">
                        <div class="flex-between-center gx-0 row">
                            <div class="d-flex align-items-center col-lg-auto">
                                <img class="img-fluid" src="data:image/png;base64," alt="">
                                <div class="ms-x1">
