function move_esc_marker(lat, lng)
{
    // 마커를 표시할 좌표 (위도, 경도)
    const newCoordinates = [lng, lat];  // 서울 강남

    // 새로운 좌표로 변환
    const newPoint = ol.proj.fromLonLat(newCoordinates);

    // 마커의 위치를 업데이트
    //marker.setGeometry(new ol.geom.Point(newPoint));

    // 지도 중심을 새 마커 위치로 이동
    map.getView().setCenter(newPoint);
}
</script>