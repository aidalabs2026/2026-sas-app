<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>무선국 신청</title>

    <!-- Kendo UI Stylesheet -->
    <link href="{{request.static_url('apply_emul_app:apply_emul/static/css/kendo.default-v2.min.css')}}" rel="stylesheet" />

    <link href="{{request.static_url('apply_emul_app:apply_emul/static/css/theme.css')}}" rel="stylesheet" />
    <link href="{{request.static_url('apply_emul_app:apply_emul/static/css/custom.css')}}" rel="stylesheet" />

    <!-- Kendo UI and jQuery -->
    <script src="{{request.static_url('apply_emul_app:apply_emul/static/js/jquery-3.6.0.min.js')}}"></script>
    <script src="{{request.static_url('apply_emul_app:apply_emul/static/js/kendo.all.min.js')}}"></script>
    <script src="{{request.static_url('apply_emul_app:apply_emul/static/js/AppCommon.js')}}"></script>
    <script>
    var dataTable;
    var delNonOtData = [];

    $(document).ready(function() {
        init();
    });

    function init() {
        init_datatable();
        load();

        radioClick();
        refresh();
    }

    function init_datatable() {
        $("#dataTable").kendoGrid({
            scrollable: false,
            sortable: true,
            selectable: true,
            toolbar: [
                // 왼쪽 (삭제 버튼)
                { name: "deleteRow", text: "🗑 삭제" },

                // 오른쪽 (전체/주기적/비주기적 버튼 묶음)
                {
                  template: `
                    <div style="margin-left:auto;">
                      <a class="k-button k-button-icontext k-grid-fullList">전체</a>
                      <a class="k-button k-button-icontext k-grid-periodicList">주기적</a>
                      <a class="k-button k-button-icontext k-grid-nonPeriodicList">비주기적</a>
                    </div>
                  `
                }
            ],
            pageable: {
                responsive: false,
                buttonCount : 5
            },
            columns: [
                {filed: "ID", hidden:true},
                {field: "no", title: "No", width: "5%", template: "#= noRowNumber #"},
                {field: "SN", title: "Serial Number", width: "25%"},
                {field: "DPA_NM", title: "N-DPA NAME", width: "25%"},
                {field: "REGIST_DT", title: "신청 날짜", template : '#=REGIST_DT==null?" ":new Date(REGIST_DT).getDateTime2()#', width: "15%"},
                {field: "PERIOD_TYPE", title: "운용 타입", template : '#=PERIOD_TYPE=="periodic"?"주기적":"비주기적"#', width: "15%"},
                {field: "stus", title: "운용 상태", width: "15%"}
            ],
            dataBound: function(e) {
                var grid = this;
                var data = grid.dataSource.view(); // 현재 페이지 & 필터 적용된 데이터
                var page = grid.dataSource.page() || 1;
                var pageSize = grid.dataSource.pageSize();

                for (var i = 0; i < data.length; i++) {
                    data[i].noRowNumber = (page - 1) * pageSize + i + 1;
                }
            },
            selectable: "row",
            change: function(e) {
                delNonOtData = [];
                $(".eachContainer .selectRow").prop("checked", false); //체크박스 초기화
                var selectedRow = this.select();
                var dataItem = this.dataItem(selectedRow);

                applyView(dataItem);
            }
        });
        dataTable = $("#dataTable").data("kendoGrid");

        $(document).on("click", ".k-grid-deleteRow", function () {
            var selected = dataTable.select();

            if (selected.length === 0) {
                alert("삭제할 행을 선택하세요.");
                return;
            }

            var dataItem = dataTable.dataItem(selected);

            var id = dataItem.ID;

            applyDel(id);
        });

        //툴바에서 전체버튼 클릭
        $(document).on("click", ".k-grid-fullList", function () {
            var grid = $("#dataTable").data("kendoGrid");
            grid.dataSource.filter([]);
            updateRowNum();
        });

        //툴바에서 주기적버튼 클릭
        $(document).on("click", ".k-grid-periodicList", function () {
            var grid = $("#dataTable").data("kendoGrid");
            grid.dataSource.filter({
                field: "PERIOD_TYPE",
                operator: "eq",
                value: "periodic"
            });
            updateRowNum();
        });

        //툴바에서 비주기적버튼 클릭
        $(document).on("click", ".k-grid-nonPeriodicList", function () {
            var grid = $("#dataTable").data("kendoGrid");
            grid.dataSource.filter({
                field: "PERIOD_TYPE",
                operator: "eq",
                value: "nonPeriodic"
            });
            updateRowNum();
        });
    }
    </script>
    <style>

    </style>
</head>
<body>
    <main class="main" id="main">
        <div class="container">
            <div class="content">
                <div class="shadow-none border card" style="margin-bottom:10px;">
                    <div class="z-1 card-header">
                        <div class="flex-between-center gx-0 row">
                            <div class="d-flex align-items-center col-lg-auto">
                                <img class="img-fluid" src="data:image/png;base64," alt="">
                                <div class="ms-x1">
                                    <h6 class="mb-1 text-primary">ETRI</h6>
                                    <h4 class="mb-0 text-primary fw-bold">무선국 신청</h4>
                                </div>
                            </div>
                            <div class="pt-3 pt-lg-0 col-lg-auto">
                                <div class="flex-lg-column flex-xxl-row gx-3 gy-2 align-items-center align-items-lg-start align-items-xxl-center row">
                                    <div class="col-auto"><h6 class="text-700 mb-0"></h6>
                                    </div>
                                    <div class="col-md-auto">

                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <form id="reqForm" class>
                    <div class="g-3 row">
                        <div class="col-lg-4">
                            <div class="sticky-sidebar">
                                <div class="mb-3 card">
                                    <h6 class="bg-body-tertiary card-header">신청 List</h6>
                                    <div class="p-0 card-body">
                                        <div id="dataTable" class="table-responsive scrollbar"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-4">
                            <div class="sticky-sidebar">
                                <div class="mb-3 card">
                                    <h6 class="bg-body-tertiary card-header">
                                      Information
                                      <img src="{{ request.static_url('apply_emul_app:apply_emul/static/images/icon/refresh.png')}}" alt="refresh"
                                            style="width:18px; height:18px; float:right; cursor:pointer;"
                                            class="refresh-icon">
                                    </h6>
                                    <div class="card-body">
                                        <form>
                                            {% include "include/inc_apply_form.jinja2" %}
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </main>
</body>
</html>
<script>
function load() {
    $.ajax({
        url: '{{request.route_url("api/apply_list")}}',  // AJAX 요청할 URL
        method: 'GET',
        success: function(response) {
            var data = response.applications;

            var pageSize = 12;
            var page = $("#dataTable").data("kendoGrid").dataSource.page();
            if (!page) page = 1;

            for (var i = 0; i < data.length; i++) {
                data[i].noRowNumber = (page - 1) * pageSize + i + 1;
            }

            var now = new Date();

            for (var i = 0; i < data.length; i++) {
                if (data[i].PERIOD_TYPE === "periodic") {
                    var start = new Date(data[i].PERIODIC_START);
                    var end   = new Date(data[i].PERIODIC_END);
                    end.setHours(23, 59, 59);

                    if (now >= start && now <= end) {
                        data[i].stus = "운용 중";
                    } else if (now < start) {
                        data[i].stus = "운용 예정";
                    } else {
                        data[i].stus = "운용 종료";
                    }

                }else {
                    var nonPeriodicTime = data[i].nonPeriodicTime;
                    var isRunning = false;
                    var isFuture = false;

                    for (var j = 0; j < nonPeriodicTime.length; j++) {
                        var nonStart = new Date(nonPeriodicTime[j].NON_PERIODIC_START);
                        var nonEnd   = new Date(nonPeriodicTime[j].NON_PERIODIC_END);

                        if (now >= nonStart && now <= nonEnd) {
                            isRunning = true;
                            break; // 하나라도 해당 기간이면 "운영중" 확정
                        } else if (now < nonStart) {
                            isFuture = true; // 미래 기간 있음
                        }
                    }

                    if (isRunning) {
                        data[i].stus = "운용 중";
                    } else if (isFuture) {
                        data[i].stus = "운용 예정";
                    } else {
                        data[i].stus = "운용 종료";
                    }
                }
            }

            var dataSource = new kendo.data.DataSource({
                data: data,
                pageSize: pageSize
            });

            dataTable.setDataSource(dataSource);

            //새로 신청정보를 등록하는 경우 첫번째 row로 생성되기 때문에 load시 첫번째 row클릭
            var applyStus = $("#applyStus").val();
            var id = $(".form_container #ID").val();
            if(applyStus == "firstApply") {
                var firstRow = dataTable.tbody.find("tr").first(); // tbody에서 첫 번째 tr 가져오기
	            firstRow.trigger("click");

	            $("#applyStus").val("");
            }else if(id){ //업데이트인 경우 업데이트 항목을 클릭된 상태로 유지
                var allData = dataTable.dataSource.data();
				var pageSize = dataTable.dataSource.pageSize();
				var index = -1;

				var dataItem = allData.find(function(item, i) {
					if (item.ID == id) {
					    index = i; // 인덱스 저장
						return true;
				    }
					return false;
				});

				if (dataItem && index !== -1) {
				    var page = Math.floor(index / pageSize) + 1;
					dataTable.dataSource.page(page);

					var row = dataTable.tbody.find("tr[data-uid='" + dataItem.uid + "']");
					if (row.length) {
					    row.trigger("click");
					}
				}
            }
        },
        error: function() {
            console.log('Error occurred while fetching data.');
        }
    });
}

function applyView(data) {
    console.log(data);

    //리스트 row클릭시 area,pattern 배열을 초기화
    rxAntPattern = [];
    rxArea = [];

    var columnKeys = Object.keys(data);

	for(i = 0 ; i < columnKeys.length ; i++) {
    	if(columnKeys[i] == "RX_AREA") {
            var rxAreaData = data.RX_AREA;
            rxArea.push(rxAreaData);
    	}else if(columnKeys[i] == "RX_ANT_PATTERN") {
            var rxAntPatternData = data.RX_ANT_PATTERN;
            rxAntPattern = JSON.parse(rxAntPatternData);
    	}else if(columnKeys[i] == "PERIODIC_DAY") {
            $("#reqForm").find("#weekday").val(data.PERIODIC_DAY);
    	}else if(columnKeys[i] == "PERIODIC_START") {
            $("#reqForm").find("#startDateTime").val(data.PERIODIC_START);
    	}else if(columnKeys[i] == "PERIODIC_END") {
            $("#reqForm").find("#endDateTime").val(data.PERIODIC_END);
    	}else if(columnKeys[i] == "PERIODIC_START_TIME") {
            $("#reqForm").find("#startTime").val(data.PERIODIC_START_TIME);
    	}else if(columnKeys[i] == "PERIODIC_END_TIME") {
            $("#reqForm").find("#endTime").val(data.PERIODIC_END_TIME);
    	}else if(columnKeys[i] == "PERIOD_TYPE"){
            var periodType = data.PERIOD_TYPE;
            $("input[name='PERIOD_TYPE'][value='" + periodType + "']").trigger('click');
    	}else{
    		var findElm = $("#reqForm").find("#"+columnKeys[i]);

    		if( findElm.is("input"))
    			$("#reqForm").find("#"+columnKeys[i]).val(data[columnKeys[i]]);
    		else
    			$("#reqForm").find("#"+columnKeys[i]).text(data[columnKeys[i]]);
    	}
    }

    var nonPeriodicList  = data.nonPeriodicTime;
    if (nonPeriodicList.length > 0) {
        //row를 클릭할때마다 생성되는것을 방지
        $("#operTimeContainer .eachContainer").not(":first").remove();

        $("#operTimeContainer .eachContainer:eq(0) #nonOtId").val(nonPeriodicList[0].ID);
        $("#operTimeContainer .eachContainer:eq(0) #startDateTimeNon").val(nonPeriodicList[0].NON_PERIODIC_START); // HH:mm
        $("#operTimeContainer .eachContainer:eq(0) #endDateTimeNon").val(nonPeriodicList[0].NON_PERIODIC_END);

        for (var i = 1; i < nonPeriodicList.length; i++) {
            var item = nonPeriodicList[i];
            var newBlock = $(
                '<div class="input-group mb-2 eachContainer">' +
                '<input type="hidden" id="nonOtId" name="nonOtId" value="' + item.ID + '"/>' +
                '<div class="input-group-text">' +
                '<input type="checkbox" class="form-check-input selectRow">' +
                '</div>' +
                '<label class="input-group-text" for="startDateTime">시작</label>' +
                '<input type="datetime-local" class="form-control" id="startDateTimeNon" value="' + item.NON_PERIODIC_START + '">' +
                '<label class="input-group-text" for="endDateTime">종료</label>' +
                '<input type="datetime-local" class="form-control" id="endDateTimeNon" value="' + item.NON_PERIODIC_END + '">' +
                '</div>'
            );
            $("#operTimeContainer").append(newBlock);
        }
    }

}

function applyDel(id) {
    if(confirm("해당 행을 삭제하시겠습니까?")) {
        $.ajax({
            url: '{{request.route_url("api/applyDel")}}'+"?id="+id,  // AJAX 요청할 URL
            method: 'GET',
            success: function(response) {
                console.log(response);  // 응답 처리

                //입력 필드 초기화
                fieldReset();

                load();
            },
            error: function() {
                console.log('Error occurred while fetching data.');
            }
        });
    }
}

function updateRowNum() {
    var grid = $("#dataTable").data("kendoGrid");
    var data = grid.dataSource.view(); // 현재 페이지 & 필터 적용된 데이터
    var page = grid.dataSource.page() || 1;
    var pageSize = grid.dataSource.pageSize();

    for (var i = 0; i < data.length; i++) {
        data[i].noRowNumber = (page - 1) * pageSize + i + 1;
    }

    grid.refresh();
}

function formatDate(date) {
    var year   = date.getFullYear();
    var month  = String(date.getMonth() + 1).padStart(2, '0');
    var day    = String(date.getDate()).padStart(2, '0');
    var hour   = String(date.getHours()).padStart(2, '0');
    var minute = String(date.getMinutes()).padStart(2, '0');
    var second = String(date.getSeconds()).padStart(2, '0');

    return year + "-" + month + "-" + day + " " + hour + ":" + minute + ":" + second;
}

function refresh() {
    $(".refresh-icon").on("click", function() {
        var grid = $("#dataTable").data("kendoGrid");
        grid.refresh();

        fieldReset();
    });
}
</script>