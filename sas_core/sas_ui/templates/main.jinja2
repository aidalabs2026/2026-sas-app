<!DOCTYPE html>
<html lang="en" class="windows chrome">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VIRTUAL ESC V1.0</title>
    <!-- Kendo UI Stylesheet -->
    <link href="{{request.static_url('app:static/css/kendo.default-v2.min.css')}}" rel="stylesheet" />

    <link href="{{request.static_url('app:static/css/theme.css')}}" rel="stylesheet" />

    <!-- Kendo UI and jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="{{request.static_url('app:static/js/kendo.all.min.js')}}"></script>
    <script src="{{request.static_url('app:static/js/AppCommon.js')}}"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/echarts/5.4.2/echarts.min.js"></script>
    <script>
    var dataTable;

    $(document).ready(function() {
        init();

        load();
    });

    function init()
    {
        init_datatable()
    }

    function init_datatable() {
        $("#dataTable").kendoGrid({
            sortable: true,
            selectable: true,
            pageable: false,
            columns: [
                {field: "ID", title: "ID", width: "100px"},
                {field: "SENSOR_ID", title: "ESC ID", width: "100px"},
                {field: "LAT", title: "LAT.", width: "160px"},
                {field: "LNG", title: "LNG.", width: "100px"},
                {field: "HEIGHT", title: "HEIGHT", width: "100px"},
                {field: "HEIGHT_TYPE", title: "HEIGHT_TYPE", width: "100px"}
            ],
            // 로우 클릭 이벤트 핸들러
            selectable: "row",
            change: function(e) {
                var selectedRow = this.select();
                var dataItem = this.dataItem(selectedRow);
                var keys = Object.keys(dataItem)

                for( var i = 0 ; i < keys.length ; i++ )
                {
                    if(keys[i] == "STATUS" )
                        $("#status_label").text(dataItem[keys[i]])
                    else if(keys[i] == "AZIMUTH_RAD_PATTERN") {
                        var radarData = JSON.parse(dataItem[keys[i]])
                        init_chart("radarChart", radarData)
                    }
                    else if(keys[i] == "ELEVATION_RAD_PATTERN") {
                        var radarData = JSON.parse(dataItem[keys[i]])
                        init_chart("radarChart2", radarData)
                    }
                    else
                        $("#"+keys[i]).val(dataItem[keys[i]])
                }

                get_ch_list(dataItem.SENSOR_ID)
            }
        });
        dataTable = $("#dataTable").data("kendoGrid");
    }

    function init_chart(name, data)
    {
        /*
        const data = [
            {"gain": 20, "angle": 1}, {"gain": 20, "angle": 2}, {"gain": 20, "angle": 3},
            {"gain": 20, "angle": 4}, {"gain": 20, "angle": 5}, {"gain": 20, "angle": 6},
            // ... 생략 ...
            {"gain": 20, "angle": 359}, {"gain": 20, "angle": 360}
        ];
        */
        // ECharts 인스턴스 생성
        const chartDom = document.getElementById(name);
        const myChart = echarts.init(chartDom);

        // 각도 배열과 값 배열 생성
        const polarDatas = data.map(item => [item.gain, item.angle]);
        const gains = data.map(item => item.gain);

        // 옵션 설정
        option = {
          title: {
            text: ''
          },
          legend: {
            data: ['gain'],
            show:false
          },
          polar: {},
          tooltip: {
            trigger: 'axis',
            axisPointer: {
              type: 'cross'
            }
          },
          angleAxis: {
            type: 'value',
            startAngle: 0
          },
          radiusAxis: {},
          series: [
            {
              coordinateSystem: 'polar',
              name: 'gain',
              type: 'line',
              data: polarDatas
            }
          ]
        };
        // 옵션 설정 및 차트 표시
        myChart.setOption(option);
    }

    const ws = new WebSocket('ws://localhost:8766/ws');
    const messagesDiv = document.getElementById('messages');

    ws.onopen = () => {
        console.log('WebSocket connection opened');
    };

    ws.onmessage = (event) => {
        console.log(event.data)
        const jsonObject = JSON.parse(event.data);

        if( jsonObject.status == "SUSPENDED_GRANT" )
        {
            //alert("channel SUSPENDED_GRANT")
            get_grant_list(jsonObject.cbsd_id)
        }

    };

    ws.onclose = () => {
        console.log('WebSocket connection closed');
    };

    </script>

</head>
<body>
    <main class="main" id="main">
        <div class="container">
            <div class="content">
                <div class="shadow-none border card" style="margin-bottom:10px;">
                    <div class="z-1 card-header">
                        <div class="flex-between-center gx-0 row">
                            <div class="d-flex align-items-center col-lg-auto">
                                <img class="img-fluid" src="data:image/png;base64," alt="">
                                <div class="ms-x1">
                                    <h6 class="mb-1 text-primary">ETRI</h6>
                                    <h4 class="mb-0 text-primary fw-bold">VIRTUAL<span class="text-info fw-medium"> ESC - v1.0</span></h4>
                                </div>
                            </div>
                            <div class="pt-3 pt-lg-0 col-lg-auto">
                                <div class="flex-lg-column flex-xxl-row gx-3 gy-2 align-items-center align-items-lg-start align-items-xxl-center row">
                                    <div class="col-auto"><h6 class="text-700 mb-0"></h6>
                                    </div>
                                    <div class="col-md-auto">

                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <form class>
                    <div class="g-3 row">
                        <div class="col-lg-4">
                            <div class="sticky-sidebar">
                                <div class="mb-3 card">
                                    <h6 class="bg-body-tertiary card-header">ESC List</h6>
                                    <div class="p-0 card-body">
                                        <div id="dataTable" class="table-responsive scrollbar"></div>
                                    </div>
                                </div>

                            </div>
                        </div>
                        <div class="col-lg-4">
                            <div class="sticky-sidebar">
                                <div class="mb-3 card">
                                    <h6 class="bg-body-tertiary card-header">Information</h6>
                                    <div class="card-body">
                                        <form>
                                            {% include "include/inc_esc_form.jinja2" %}
                                        </form>
                                    </div>
                                </div>

                            </div>
                        </div>
                        <div class="col-lg-4">
                            <div class="sticky-sidebar">
                                <div class="mb-3 card">
                                    <h6 class="bg-body-tertiary card-header">Status</h6>
                                    <div class="card-body">
                                        {% include "include/inc_esc_channel.jinja2" %}
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </main>

    <script>
        // Kendo Grid 초기화
        $(document).ready(function () {
            $("#grid").kendoGrid({
                dataSource: {
                    data: [
                        { name: "홍길동", age: 30, city: "서울" },
                        { name: "김영희", age: 25, city: "부산" },
                        { name: "박철수", age: 35, city: "대전" }
                    ],
                    schema: {
                        model: {
                            fields: {
                                name: { type: "string" },
                                age: { type: "number" },
                                city: { type: "string" }
                            }
                        }
                    },
                    pageSize: 5
                },
                height: 200,
                pageable: true,
                columns: [
                    { field: "name", title: "이름", width: "150px" },
                    { field: "age", title: "나이", width: "100px" },
                    { field: "city", title: "도시", width: "150px" }
                ]
            });
        });
    </script>
</body>
</html>
<script>
function load() {
    $.ajax({
        url: '{{request.route_url("api/esc_list")}}',  // AJAX 요청할 URL
        method: 'GET',
        success: function(response) {
            console.log(response);  // 응답 처리

            var data = JSON.parse(response);

           dataTable.setDataSource(data);

            console.log(data)
        },
        error: function() {
            console.log('Error occurred while fetching data.');
        }
    });
}

function get_ch_list(sensorId) {

    _ch_list = null

    $("#ch_status").val("")
    $("#ch_freq_range").val("")

    $.ajax({
        url: '{{request.route_url("api/esc_ch_list")}}'+"?sensor_id="+sensorId,  // AJAX 요청할 URL
        method: 'GET',
        success: function(response) {
            console.log(response);  // 응답 처리

            var data = JSON.parse(response);

            for( var i = 1 ; i < 11 ; i++ )
            {
                $("#ch" + i).css("background-color", "#7efa5f")
            }

            _ch_list = data

            for( var i = 0 ; i < data.length ; i++ )
            {
                var item = data[i]
                if( item.INCUMBENT_USER == 1 )
                    $("#ch" + item.CH_NO).css("background-color", "ORANGE")
                else
                    $("#ch" + item.CH_NO).css("background-color", "#7efa5f")
            }

            console.log(data)
        },
        error: function() {
            console.log('Error occurred while fetching data.');
        }
    });
}
</script>