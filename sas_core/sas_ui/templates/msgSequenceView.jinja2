<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>JSON to Sequence Diagram Example</title>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>




    // Function to refresh the iframe
    function refreshIframe() {
        const iframe = document.getElementById('mermaid-frame');
        const src = iframe.src; // Get the current source
        iframe.src = ''; // Clear the src
        iframe.src = src; // Reset the src to refresh
    }

    // Set the interval to refresh the iframe every 5 seconds
    setInterval(refreshIframe, 5000); // Adjust the interval as needed
    </script>
    <style>
         body {
            display: flex;
            justify-content: center;
            align-items: flex-start; /* 상단 정렬 */
            height: 100vh; /* 전체 높이를 브라우저 높이에 맞춤 */
            margin: 0; /* 기본 여백 제거 */
        }
        #mermaid-diagram {
            width: 100%; /* 다이어그램 영역의 너비 */
            height: 80vh; /* 고정된 높이 (브라우저 전체) */
            overflow-y: auto; /* 수직 스크롤 */
            border: 1px solid #ccc; /* 테두리 추가 */
            margin-right: 20px; /* 오른쪽 여백 */
        }
        #log-area {
            width: 100%; /* 로그 영역의 너비 */
            height: 70vh; /* 로그 영역의 높이 */
            border: 1px solid #ccc; /* 테두리 추가 */
        }
        textarea {
            width: 500px;
            height: 500px;
            resize: none;
            border: 4;
            padding: 10px;
            box-sizing: border-box;
            padding: 10px; /* 내부 여백 */
            box-sizing: border-box; /* 패딩을 포함한 박스 크기 조정 */
        }
    </style>
</head>
<body>
    <div id="mermaid-container" style="width:500px">
        <iframe id="mermaid-frame" src="http://127.0.0.1:6544/msglog/{{device_id}}" style="width: 100%; height: 100vh; border: none;">
        </iframe>
    </div>
    <div id="log-container">
        <h3>Protocol Message</h3>
        <h4 id="message-title"></h4>
        <textarea id="message-log" readonly></textarea>
    </div>
</body>
</html>
<script>


</script>